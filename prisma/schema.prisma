generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model ct_categoria {
  id_ct_categoria      Int           @id @default(autoincrement())
  nombre               String        @unique @db.VarChar(100)
  descripcion          String?       @db.VarChar(500)
  estado               Boolean       @default(true)
  fecha_reg            DateTime      @default(now()) @db.DateTime(0)
  fecha_mod            DateTime?     @db.DateTime(0)
  id_ct_usuario_reg    Int
  id_ct_usuario_mod    Int?
  usuario_modificacion ct_usuario?   @relation("ct_categoria_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_categoria_ct_usuario_mod")
  usuario_registro     ct_usuario    @relation("ct_categoria_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_categoria_ct_usuario_reg")
  ct_platillo          ct_platillo[]

  @@index([id_ct_usuario_mod], map: "FK_ct_categoria_ct_usuario_mod")
  @@index([id_ct_usuario_reg], map: "FK_ct_categoria_ct_usuario_reg")
  @@index([estado])
}

model ct_cliente {
  id_ct_cliente        Int              @id @default(autoincrement())
  nombre               String           @db.VarChar(100)
  correo               String           @db.VarChar(255)
  telefono             String           @db.VarChar(20)
  estado               Boolean          @default(true)
  fecha_reg            DateTime         @default(now()) @db.DateTime(0)
  fecha_mod            DateTime?        @db.DateTime(0)
  id_ct_usuario_reg    Int
  id_ct_usuario_mod    Int?
  usuario_modificacion ct_usuario?      @relation("ct_cliente_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_cliente_ct_usuario_mod")
  usuario_registro     ct_usuario       @relation("ct_cliente_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_cliente_ct_usuario_reg")
  rl_reservacion       rl_reservacion[]

  @@index([id_ct_usuario_mod], map: "FK_ct_cliente_ct_usuario_mod")
  @@index([id_ct_usuario_reg], map: "FK_ct_cliente_ct_usuario_reg")
  @@index([estado], map: "estado")
}

// ── Catálogo de estados de reservación ────────────────────────────────────────
// Usa tabla catálogo en lugar de enum porque:
//   - Más de 4 estados → mejor diseño normalizado
//   - Permite agregar nuevos estados sin necesidad de una migración de schema
//   - Los estados pueden tener metadatos (descripción, si implica pago activo, etc.)
//   - El frontend puede consumir /api/estados-reservacion para renderizar dinero filtros
model ct_estado_reservacion {
  id_ct_estado_reservacion Int              @id @default(autoincrement())

  // Clave técnica usada en el código para comparaciones (ej: 'PENDIENTE_PAGO')
  clave                    String           @unique @db.VarChar(50)

  // Nombre legible para mostrar en el frontend y panel de administración
  nombre                   String           @db.VarChar(100)

  // Descripción del estado: qué significa y cuándo ocurre
  descripcion              String?          @db.VarChar(255)

  // Indica si en este estado hay un intento de pago activo en Stripe
  // (autorizado pero no capturado). Útil para que el cron job de no-shows
  // filtre rápido qué reservaciones requieren acción de cobro.
  implica_pago_activo      Boolean          @default(false)

  // Soft-delete: false = estado desactivado (no aparece en el sistema)
  estado                   Boolean          @default(true)
  fecha_reg                DateTime         @default(now()) @db.DateTime(0)

  // Relación inversa: reservaciones que actualmente tienen este estado
  rl_reservacion           rl_reservacion[]

  // Índices para búsqueda por clave (la más común) y por estado activo
  @@index([clave])
  @@index([estado])
}

model ct_mesa {
  id_ct_mesa           Int              @id @default(autoincrement())
  codigo               String           @unique @db.VarChar(50)
  capacidad            Int
  status               String           @default("libre") @db.VarChar(20)
  estado               Boolean          @default(true)
  fecha_reg            DateTime         @default(now()) @db.DateTime(0)
  fecha_mod            DateTime?        @db.DateTime(0)
  id_ct_usuario_reg    Int
  id_ct_usuario_mod    Int?
  usuario_modificacion ct_usuario?      @relation("ct_mesa_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_mesa_ct_usuario_mod")
  usuario_registro     ct_usuario       @relation("ct_mesa_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_mesa_ct_usuario_reg")
  rl_orden             rl_orden[]
  rl_reservacion       rl_reservacion[]

  @@index([id_ct_usuario_mod], map: "FK_ct_mesa_ct_usuario_mod")
  @@index([id_ct_usuario_reg], map: "FK_ct_mesa_ct_usuario_reg")
  @@index([estado])
}

model ct_permiso {
  id_ct_permiso        Int              @id @default(autoincrement())
  nombre               String           @unique @db.VarChar(100)
  codigo               String           @unique @db.VarChar(100)
  descripcion          String?          @db.VarChar(255)
  estado               Boolean          @default(true)
  fecha_reg            DateTime         @default(now()) @db.DateTime(0)
  fecha_mod            DateTime?        @db.DateTime(0)
  id_ct_usuario_reg    Int
  id_ct_usuario_mod    Int?
  usuario_modificacion ct_usuario?      @relation("ct_permiso_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_permiso_ct_usuario_mod")
  usuario_registro     ct_usuario       @relation("ct_permiso_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_permiso_ct_usuario_reg")
  rl_rol_permiso       rl_rol_permiso[]
  ct_ruta_permiso      ct_ruta_permiso[]

  @@index([id_ct_usuario_mod], map: "FK_ct_permiso_ct_usuario_mod")
  @@index([id_ct_usuario_reg], map: "FK_ct_permiso_ct_usuario_reg")
  @@index([estado], map: "estado")
}

model ct_plantilla_correo {
  id_ct_plantilla_correo Int         @id @default(autoincrement())
  clave                  String      @unique @db.VarChar(50)
  nombre                 String      @db.VarChar(100)
  asunto                 String      @db.VarChar(200)
  contenido_html         String      @db.MediumText
  estado                 Boolean     @default(true)
  fecha_reg              DateTime    @default(now()) @db.DateTime(0)
  fecha_mod              DateTime?   @db.DateTime(0)
  id_ct_usuario_reg      Int?
  id_ct_usuario_mod      Int?
  usuario_modificacion   ct_usuario? @relation("ct_plantilla_correo_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_plantilla_correo_ct_usuario_mod")
  usuario_registro       ct_usuario? @relation("ct_plantilla_correo_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_plantilla_correo_ct_usuario_reg")

  @@index([id_ct_usuario_mod], map: "FK_ct_plantilla_correo_ct_usuario_mod")
  @@index([id_ct_usuario_reg], map: "FK_ct_plantilla_correo_ct_usuario_reg")
  @@index([estado], map: "estado")
}

model ct_platillo {
  id_ct_platillo       Int                @id @default(autoincrement())
  id_ct_categoria      Int
  nombre               String             @db.VarChar(200)
  descripcion          String?            @db.VarChar(500)
  precio               Decimal            @db.Decimal(10, 2)
  imagen_url           String?            @db.VarChar(500)
  estado               Boolean            @default(true)
  fecha_reg            DateTime           @default(now()) @db.DateTime(0)
  fecha_mod            DateTime?          @db.DateTime(0)
  id_ct_usuario_reg    Int
  id_ct_usuario_mod    Int?
  usuario_modificacion ct_usuario?        @relation("ct_platillo_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_platillo_ct_usuario_mod")
  usuario_registro     ct_usuario         @relation("ct_platillo_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_platillo_ct_usuario_reg")
  ct_categoria         ct_categoria       @relation(fields: [id_ct_categoria], references: [id_ct_categoria])
  dt_detalle_orden     dt_detalle_orden[]

  @@index([id_ct_usuario_mod], map: "FK_ct_platillo_ct_usuario_mod")
  @@index([id_ct_usuario_reg], map: "FK_ct_platillo_ct_usuario_reg")
  @@index([estado])
  @@index([id_ct_categoria, estado])
}

model ct_rol {
  id_ct_rol                               Int              @id @default(autoincrement())
  nombre                                  String           @unique @db.VarChar(100)
  descripcion                             String?          @db.VarChar(255)
  estado                                  Boolean          @default(true)
  fecha_reg                               DateTime         @default(now()) @db.DateTime(0)
  fecha_mod                               DateTime?        @db.DateTime(0)
  id_ct_usuario_reg                       Int
  id_ct_usuario_mod                       Int?
  usuario_modificacion                    ct_usuario?      @relation("ct_rol_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_rol_ct_usuario_mod")
  usuario_registro                        ct_usuario       @relation("ct_rol_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_rol_ct_usuario_reg")
  ct_usuario_ct_usuario_id_ct_rolToct_rol ct_usuario[]     @relation("ct_usuario_id_ct_rolToct_rol")
  rl_rol_permiso                          rl_rol_permiso[]

  @@index([id_ct_usuario_mod], map: "FK_ct_rol_ct_usuario_mod")
  @@index([id_ct_usuario_reg], map: "FK_ct_rol_ct_usuario_reg")
  @@index([estado], map: "estado")
}

model ct_tipo_documento {
  id_ct_tipo_documento   Int            @id @default(autoincrement())
  clave                  String         @unique(map: "clave") @default("") @db.VarChar(50)
  descripcion            String         @default("") @db.VarChar(255)
  max_size_bytes         Int
  extensiones_permitidas String         @default("pdf,jpg,png") @db.VarChar(255)
  estado                 Boolean        @default(true)
  fecha_reg              DateTime       @default(now()) @db.DateTime(0)
  fecha_mod              DateTime?      @db.DateTime(0)
  id_ct_usuario_reg      Int
  id_ct_usuario_mod      Int?
  usuario_modificacion   ct_usuario?    @relation("ct_tipo_documento_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_tipo_documento_ct_usuario_mod")
  usuario_registro       ct_usuario     @relation("ct_tipo_documento_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_tipo_documento_ct_usuario_reg")
  dt_documento           dt_documento[]

  @@index([id_ct_usuario_reg], map: "ct_usuario_in")
  @@index([id_ct_usuario_mod], map: "ct_usuario_up")
  @@index([estado], map: "estado")
}

model ct_usuario {
  id_ct_usuario                   Int                   @id @default(autoincrement())
  usuario                         String                @unique @db.VarChar(100)
  contrasena                      String                @db.VarChar(255)
  email                           String?               @unique @db.VarChar(255)
  nombre_completo                 String                @db.VarChar(200)
  id_ct_rol                       Int                   @default(1)
  estado                          Boolean               @default(true)
  fecha_reg                       DateTime              @default(now()) @db.DateTime(0)
  fecha_mod                       DateTime?             @db.DateTime(0)
  id_ct_usuario_reg               Int
  id_ct_usuario_mod               Int?
  ct_categoria_modificados        ct_categoria[]        @relation("ct_categoria_id_ct_usuario_modToct_usuario")
  ct_categoria_registrados        ct_categoria[]        @relation("ct_categoria_id_ct_usuario_regToct_usuario")
  ct_cliente_modificados          ct_cliente[]          @relation("ct_cliente_id_ct_usuario_modToct_usuario")
  ct_cliente_registrados          ct_cliente[]          @relation("ct_cliente_id_ct_usuario_regToct_usuario")
  ct_mesa_modificados             ct_mesa[]             @relation("ct_mesa_id_ct_usuario_modToct_usuario")
  ct_mesa_registrados             ct_mesa[]             @relation("ct_mesa_id_ct_usuario_regToct_usuario")
  ct_permiso_modificados          ct_permiso[]          @relation("ct_permiso_id_ct_usuario_modToct_usuario")
  ct_permiso_registrados          ct_permiso[]          @relation("ct_permiso_id_ct_usuario_regToct_usuario")
  ct_plantilla_correo_modificados ct_plantilla_correo[] @relation("ct_plantilla_correo_id_ct_usuario_modToct_usuario")
  ct_plantilla_correo_registrados ct_plantilla_correo[] @relation("ct_plantilla_correo_id_ct_usuario_regToct_usuario")
  ct_platillo_modificados         ct_platillo[]         @relation("ct_platillo_id_ct_usuario_modToct_usuario")
  ct_platillo_registrados         ct_platillo[]         @relation("ct_platillo_id_ct_usuario_regToct_usuario")
  ct_rol_modificados              ct_rol[]              @relation("ct_rol_id_ct_usuario_modToct_usuario")
  ct_rol_registrados              ct_rol[]              @relation("ct_rol_id_ct_usuario_regToct_usuario")
  ct_tipo_documento_modificados   ct_tipo_documento[]   @relation("ct_tipo_documento_id_ct_usuario_modToct_usuario")
  ct_tipo_documento_registrados   ct_tipo_documento[]   @relation("ct_tipo_documento_id_ct_usuario_regToct_usuario")
  usuario_modificacion            ct_usuario?           @relation("ct_usuario_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_usuario_ct_usuario_mod")
  other_ct_usuario_modificados    ct_usuario[]          @relation("ct_usuario_id_ct_usuario_modToct_usuario")
  usuario_registro                ct_usuario            @relation("ct_usuario_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_usuario_ct_usuario_reg")
  other_usuario_registro          ct_usuario[]          @relation("ct_usuario_id_ct_usuario_regToct_usuario")
  ct_rol                          ct_rol                @relation("ct_usuario_id_ct_rolToct_rol", fields: [id_ct_rol], references: [id_ct_rol])
  dt_detalle_orden_modificados    dt_detalle_orden[]    @relation("dt_detalle_orden_id_ct_usuario_modToct_usuario")
  dt_detalle_orden_registrados    dt_detalle_orden[]    @relation("dt_detalle_orden_id_ct_usuario_regToct_usuario")
  dt_documento_modificados        dt_documento[]        @relation("dt_documento_id_ct_usuario_modToct_usuario")
  dt_documento_registrados        dt_documento[]        @relation("dt_documento_id_ct_usuario_regToct_usuario")
  dt_refresh_token                dt_refresh_token[]
  rl_orden_modificados            rl_orden[]            @relation("rl_orden_id_ct_usuario_modToct_usuario")
  rl_orden_registrados            rl_orden[]            @relation("rl_orden_id_ct_usuario_regToct_usuario")
  ordenes                         rl_orden[]            @relation("rl_orden_id_ct_usuarioToct_usuario")
  rl_reservacion_modificados      rl_reservacion[]      @relation("rl_reservacion_id_ct_usuario_modToct_usuario")
  rl_reservacion_registrados      rl_reservacion[]      @relation("rl_reservacion_id_ct_usuario_regToct_usuario")
  rl_rol_permiso_modificados      rl_rol_permiso[]      @relation("rl_rol_permiso_id_ct_usuario_modToct_usuario")
  rl_rol_permiso_registrados      rl_rol_permiso[]      @relation("rl_rol_permiso_id_ct_usuario_regToct_usuario")
  ct_ruta_permiso_modificados     ct_ruta_permiso[]     @relation("ct_ruta_permiso_id_ct_usuario_modToct_usuario")
  ct_ruta_permiso_registrados     ct_ruta_permiso[]     @relation("ct_ruta_permiso_id_ct_usuario_regToct_usuario")
  // Relación con ct_configuracion (solo modificaciones, no hay registro masivo de configuraciones)
  ct_configuracion_modificados    ct_configuracion[]    @relation("ct_configuracion_id_ct_usuario_modToct_usuario")

  @@index([id_ct_usuario_mod], map: "FK_ct_usuario_ct_usuario_mod")
  @@index([id_ct_usuario_reg], map: "FK_ct_usuario_ct_usuario_reg")
  @@index([estado])
  @@index([id_ct_rol], map: "ct_usuario_id_ct_rol_fkey")
}

model dt_bitacora {
  id_dt_bitacora   Int      @id @default(autoincrement())
  id_ct_usuario    Int?
  accion           String
  modelo           String
  registro_id      String?
  endpoint         String
  metodo           String
  ip_address       String?
  user_agent       String?
  datos_anteriores String?  @db.LongText
  datos_nuevos     String?  @db.LongText
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([id_ct_usuario])
  @@index([modelo, registro_id])
}

model dt_bloqueo_seguridad {
  id_dt_bloqueo     Int      @id @default(autoincrement())
  ip_address        String   @db.VarChar(50)
  endpoint          String   @db.VarChar(255)
  usuario_intentado String?  @db.VarChar(100)
  limite_alcanzado  Int
  user_agent        String?  @db.Text
  fecha_bloqueo     DateTime @default(now()) @db.DateTime(0)

  @@index([fecha_bloqueo])
  @@index([ip_address])
}

model dt_detalle_orden {
  id_dt_detalle_orden  Int         @id @default(autoincrement())
  id_rl_orden          Int
  id_ct_platillo       Int
  cantidad             Int
  precio_unitario      Decimal     @db.Decimal(10, 2)
  subtotal             Decimal     @db.Decimal(10, 2)
  estado               Boolean     @default(true)
  fecha_reg            DateTime    @default(now()) @db.DateTime(0)
  fecha_mod            DateTime?   @db.DateTime(0)
  id_ct_usuario_reg    Int
  id_ct_usuario_mod    Int?
  ct_platillo          ct_platillo @relation(fields: [id_ct_platillo], references: [id_ct_platillo], onDelete: NoAction, onUpdate: NoAction, map: "FK_dt_detalle_orden_ct_platillo")
  usuario_modificacion ct_usuario? @relation("dt_detalle_orden_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_dt_detalle_orden_ct_usuario_mod")
  usuario_registro     ct_usuario  @relation("dt_detalle_orden_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_dt_detalle_orden_ct_usuario_reg")
  rl_orden             rl_orden    @relation(fields: [id_rl_orden], references: [id_rl_orden], onDelete: NoAction, onUpdate: NoAction, map: "FK_dt_detalle_orden_rl_orden")

  @@index([id_ct_usuario_mod], map: "FK_dt_detalle_orden_ct_usuario_mod")
  @@index([id_ct_usuario_reg], map: "FK_dt_detalle_orden_ct_usuario_reg")
  @@index([id_ct_platillo], map: "dt_detalle_orden_id_ct_platillo_fkey")
  @@index([id_rl_orden], map: "dt_detalle_orden_id_orden_fkey")
  @@index([estado], map: "estado")
}

model dt_documento {
  id_dt_documento      Int               @id @default(autoincrement())
  nombre_original      String            @db.VarChar(255)
  nombre_sistema       String            @db.VarChar(255)
  ruta_relativa        String            @db.VarChar(500)
  mime_type            String            @db.VarChar(100)
  tama_o_bytes         Int               @map("tamaño_bytes")
  hash                 String            @db.VarChar(64)
  id_ct_tipo_documento Int
  modulo               String            @db.VarChar(100)
  estado               Boolean           @default(true)
  fecha_reg            DateTime          @default(now()) @db.DateTime(0)
  fecha_mod            DateTime?         @db.DateTime(0)
  id_ct_usuario_reg    Int
  id_ct_usuario_mod    Int?
  ct_tipo_documento    ct_tipo_documento @relation(fields: [id_ct_tipo_documento], references: [id_ct_tipo_documento], onDelete: NoAction, onUpdate: NoAction, map: "FK_dt_documento_ct_tipo_documento")
  usuario_modificacion ct_usuario?       @relation("dt_documento_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_dt_documento_ct_usuario_mod")
  usuario_registro     ct_usuario        @relation("dt_documento_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_dt_documento_ct_usuario_reg")

  @@index([estado], map: "estado")
  @@index([id_ct_usuario_reg], map: "id_ct_usuario_in")
  @@index([id_ct_usuario_mod], map: "id_ct_usuario_up")
  @@index([hash], map: "idx_hash")
  @@index([id_ct_tipo_documento], map: "idx_id_ct_tipo_documento")
}

model dt_refresh_token {
  id_dt_refresh_token Int        @id @default(autoincrement())
  token_hash          String     @unique(map: "token_hash") @db.VarChar(64)
  id_ct_usuario       Int
  expira_en           DateTime   @db.DateTime(6)
  revocado            Boolean    @default(false)
  revocado_en         DateTime?  @db.DateTime(0)
  reemplazado_por     Int?
  creado_en           DateTime   @default(now()) @db.DateTime(6)
  ct_usuario          ct_usuario @relation(fields: [id_ct_usuario], references: [id_ct_usuario], onDelete: Cascade)

  @@index([expira_en])
  @@index([id_ct_usuario])
  @@index([revocado, expira_en])
}

model rl_orden {
  id_rl_orden          Int                @id @default(autoincrement())
  id_ct_usuario        Int
  id_ct_mesa           Int?
  estado               rl_orden_estado    @default(PENDIENTE)
  total                Decimal            @db.Decimal(10, 2)
  fecha_reg            DateTime           @default(now()) @db.DateTime(0)
  fecha_mod            DateTime?          @db.DateTime(0)
  id_ct_usuario_reg    Int
  id_ct_usuario_mod    Int?
  dt_detalle_orden     dt_detalle_orden[]
  usuario_modificacion ct_usuario?        @relation("rl_orden_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_rl_orden_ct_usuario_mod")
  usuario_registro     ct_usuario         @relation("rl_orden_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_rl_orden_ct_usuario_reg")
  ct_mesa              ct_mesa?           @relation(fields: [id_ct_mesa], references: [id_ct_mesa], map: "dt_orden_id_ct_mesa_fkey")
  usuario              ct_usuario         @relation("rl_orden_id_ct_usuarioToct_usuario", fields: [id_ct_usuario], references: [id_ct_usuario], map: "dt_orden_id_ct_usuario_fkey")

  @@index([id_ct_usuario_mod], map: "FK_rl_orden_ct_usuario_mod")
  @@index([id_ct_usuario_reg], map: "FK_rl_orden_ct_usuario_reg")
  @@index([estado], map: "dt_orden_estado_idx")
  @@index([id_ct_mesa, estado], map: "dt_orden_id_ct_mesa_estado_idx")
  @@index([id_ct_usuario, estado], map: "dt_orden_id_ct_usuario_estado_idx")
}

// ── Reservaciones ─────────────────────────────────────────────────────────────
// Tabla principal de reservaciones. El flujo de pago se maneja mediante
// los campos de Stripe: cuando el cliente reserva, se crea un intento de
// pago (clave_intento_pago) con capture_method: 'manual'. El cargo se
// captura o libera según el comportamiento del cliente (no-show, cancelación).
model rl_reservacion {
  id_rl_reservacion    Int                    @id @default(autoincrement())
  id_ct_cliente        Int
  id_ct_mesa           Int?
  fecha_reservacion    DateTime               @db.DateTime(0)
  num_personas         Int
  notas                String?                @db.VarChar(500)

  // FK al catálogo ct_estado_reservacion (reemplaza el enum rl_reservacion_estado)
  // Se usa un catálogo porque los estados son más de 4 y tienen metadatos propios
  id_ct_estado_reservacion Int

  // ── Campos de pago Stripe ─────────────────────────────────────────────
  // Identificador único del intento de pago en Stripe.
  // Declarado @unique para garantizar idempotencia: si el webhook de Stripe
  // llega más de una vez (reintento), la base de datos rechaza el duplicado.
  clave_intento_pago       String?              @unique @db.VarChar(255)

  // Estado técnico del pago según Stripe. Distinto al estado de negocio.
  // Valores posibles: requires_capture | captured | released | canceled
  // requires_capture = autorizado, esperando acción del restaurante
  estado_pago_stripe       String?              @db.VarChar(50)

  // Monto autorizado expresado en CENTAVOS (Stripe siempre usa enteros).
  // $200 MXN = 20000. Se almacena para saber cuánto capturar en caso de no-show.
  monto_deposito_centavos  Int?

  // Horas antes de la reservación en que el cliente puede cancelar sin cargo.
  // Se copia de ct_configuracion.horas_gracia_cancelacion al crear la reservación
  // para que cambios futuros en la configuración no afecten reservaciones pasadas.
  horas_gracia_cancelacion Int                  @default(24)

  fecha_reg            DateTime               @default(now()) @db.DateTime(0)
  fecha_mod            DateTime?              @db.DateTime(0)
  id_ct_usuario_reg    Int
  id_ct_usuario_mod    Int?

  // Relaciones
  ct_cliente           ct_cliente             @relation(fields: [id_ct_cliente], references: [id_ct_cliente], onDelete: NoAction, onUpdate: NoAction, map: "FK_rl_reservacion_ct_cliente")
  ct_mesa              ct_mesa?               @relation(fields: [id_ct_mesa], references: [id_ct_mesa], onDelete: NoAction, onUpdate: NoAction, map: "FK_rl_reservacion_ct_mesa")
  ct_estado_reservacion ct_estado_reservacion @relation(fields: [id_ct_estado_reservacion], references: [id_ct_estado_reservacion], onDelete: NoAction, onUpdate: NoAction, map: "FK_rl_reservacion_ct_estado")
  usuario_modificacion ct_usuario?            @relation("rl_reservacion_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_rl_reservacion_ct_usuario_mod")
  usuario_registro     ct_usuario             @relation("rl_reservacion_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_rl_reservacion_ct_usuario_reg")

  @@index([id_ct_usuario_mod], map: "FK_rl_reservacion_ct_usuario_mod")
  @@index([id_ct_usuario_reg], map: "FK_rl_reservacion_ct_usuario_reg")
  // Índice compuesto para el cron job de no-shows: busca reservaciones
  // con estado CONFIRMADA cuya fecha ya pasó (fecha_reservacion < ahora)
  @@index([fecha_reservacion, id_ct_estado_reservacion], map: "idx_reservacion_fecha_estado")
  @@index([id_ct_mesa], map: "dt_reservacion_id_ct_mesa_fkey")
  @@index([id_ct_cliente], map: "dt_reservacion_id_ct_usuario_fkey")
  // Índice de idempotencia para lookup rápido del webhook de Stripe
  @@index([clave_intento_pago], map: "idx_reservacion_intento_pago")
}

model rl_rol_permiso {
  id_rl_rol_permiso    Int         @id @default(autoincrement())
  id_ct_rol            Int
  id_ct_permiso        Int
  estado               Boolean     @default(true)
  fecha_reg            DateTime    @default(now()) @db.DateTime(0)
  fecha_mod            DateTime?   @db.DateTime(0)
  id_ct_usuario_reg    Int
  id_ct_usuario_mod    Int?
  usuario_modificacion ct_usuario? @relation("rl_rol_permiso_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_rl_rol_permiso_ct_usuario_mod")
  usuario_registro     ct_usuario  @relation("rl_rol_permiso_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_rl_rol_permiso_ct_usuario_reg")
  ct_permiso           ct_permiso  @relation(fields: [id_ct_permiso], references: [id_ct_permiso], onDelete: Cascade, map: "dt_rol_permiso_id_ct_permiso_fkey")
  ct_rol               ct_rol      @relation(fields: [id_ct_rol], references: [id_ct_rol], onDelete: Cascade, map: "dt_rol_permiso_id_ct_rol_fkey")

  @@unique([id_ct_rol, id_ct_permiso], map: "dt_rol_permiso_id_ct_rol_id_ct_permiso_key")
  @@index([id_ct_usuario_mod], map: "FK_rl_rol_permiso_ct_usuario_mod")
  @@index([id_ct_usuario_reg], map: "FK_rl_rol_permiso_ct_usuario_reg")
  @@index([id_ct_permiso], map: "dt_rol_permiso_id_ct_permiso_fkey")
  @@index([estado], map: "estado")
}

// ── Mapeo dinámico ruta → permiso ──────────────────────────────────────────────
// Cada registro indica qué permiso se requiere para acceder a una ruta+método.
// El middleware `autorizar` consulta esta tabla (vía cache en memoria) en cada request.
// Permite configurar la autorización sin tocar código.
model ct_ruta_permiso {
  id_ct_ruta_permiso   Int        @id @default(autoincrement())
  metodo               String     @db.VarChar(10)  // 'GET', 'POST', 'PATCH', 'PUT', 'DELETE'
  ruta                 String     @db.VarChar(255) // '/api/usuarios', '/api/platillos'
  id_ct_permiso        Int
  descripcion          String?    @db.VarChar(255)
  estado               Boolean    @default(true)
  fecha_reg            DateTime   @default(now()) @db.DateTime(0)
  fecha_mod            DateTime?  @db.DateTime(0)
  id_ct_usuario_reg    Int
  id_ct_usuario_mod    Int?
  ct_permiso           ct_permiso @relation(fields: [id_ct_permiso], references: [id_ct_permiso], onDelete: Cascade, map: "FK_ct_ruta_permiso_ct_permiso")
  usuario_registro     ct_usuario @relation("ct_ruta_permiso_id_ct_usuario_regToct_usuario", fields: [id_ct_usuario_reg], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_ruta_permiso_ct_usuario_reg")
  usuario_modificacion ct_usuario? @relation("ct_ruta_permiso_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_ruta_permiso_ct_usuario_mod")

  @@unique([metodo, ruta], map: "uq_ct_ruta_permiso_metodo_ruta")
  @@index([estado])
  @@index([id_ct_permiso], map: "FK_ct_ruta_permiso_ct_permiso")
  @@index([id_ct_usuario_reg], map: "FK_ct_ruta_permiso_ct_usuario_reg")
  @@index([id_ct_usuario_mod], map: "FK_ct_ruta_permiso_ct_usuario_mod")
}

// ── Enums ───────────────────────────────────────────────────────────────────────
// Nota: rl_reservacion_estado fue reemplazado por la tabla catálogo
// ct_estado_reservacion para soportar más de 4 estados con metadatos propios.

enum rl_orden_estado {
  PENDIENTE
  EN_PROCESO
  LISTO
  ENTREGADO
  PAGADA
  CANCELADO
}

// ── Configuración del restaurante ───────────────────────────────────────────────
model ct_configuracion {
  id_ct_configuracion  Int       @id @default(autoincrement())
  nombre_restaurante   String    @db.VarChar(100)
  logo_url             String?   @db.VarChar(500)
  telefono             String?   @db.VarChar(20)
  direccion            String?   @db.VarChar(255)
  email_contacto       String?   @db.VarChar(255)
  horario_apertura     String?   @db.VarChar(50) // Ej: "10:00"
  horario_cierre       String?   @db.VarChar(50) // Ej: "22:00"
  moneda               String    @default("$") @db.VarChar(10)
  impuesto_porcentaje  Decimal   @default(0.16) @db.Decimal(5, 2)

  // ── Configuración de pagos Stripe ──────────────────────────────────────────
  // Monto cobrado al cliente si no se presenta (no-show).
  // En centavos para compatibilidad directa con Stripe (que no acepta decimales).
  // Default: 20000 centavos = $200 MXN
  monto_penalizacion_centavos Int     @default(20000)

  // Horas mínimas de antelación para cancelar sin cargo.
  // Si el cliente cancela DESPUÉS de este umbral, se aplica la penalización.
  // Default: 24 horas
  horas_gracia_cancelacion    Int     @default(24)

  fecha_mod            DateTime? @db.DateTime(0)
  id_ct_usuario_mod    Int?
  usuario_modificacion ct_usuario? @relation("ct_configuracion_id_ct_usuario_modToct_usuario", fields: [id_ct_usuario_mod], references: [id_ct_usuario], onDelete: NoAction, onUpdate: NoAction, map: "FK_ct_configuracion_ct_usuario_mod")

  @@index([id_ct_usuario_mod], map: "FK_ct_configuracion_ct_usuario_mod")
}
