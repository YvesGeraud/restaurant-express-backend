NODE_ENV=development
PORT=3000

# CORS — orígenes permitidos (separar con coma si hay más de uno)
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# ── Base de datos ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DBNAMES=restaurante
DB_USER=root
DB_PASSWORD=root
DATABASE_URL="mysql://root:root@localhost:3306/restaurante"

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=otro_secreto_diferente_para_refresh
JWT_REFRESH_EXPIRES_IN=7d

# ── Bcrypt ─────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── APIs externas ──────────────────────────────────────────────────────────────
API_EXTERNA_URL=https://ejemplo.com/api

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Las claves de TEST tienen el prefijo sk_test_ / pk_test_
# Las claves de PRODUCCIÓN tienen el prefijo sk_live_ / pk_live_
# Obtenerlas en: https://dashboard.stripe.com/apikeys

# Clave secreta del servidor — NUNCA exponerla al cliente ni subirla a Git
STRIPE_SECRET_KEY=sk_test_REEMPLAZAR_CON_TU_CLAVE

# Clave pública — esta sí se puede enviar al frontend (Stripe.js la necesita)
STRIPE_PUBLISHABLE_KEY=pk_test_REEMPLAZAR_CON_TU_CLAVE

# Secreto del webhook — se genera al registrar el endpoint en el dashboard de Stripe
# En desarrollo se obtiene ejecutando: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_REEMPLAZAR_CON_TU_SECRETO
